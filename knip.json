{
  "$schema": "./node_modules/knip/schema.json",
  "ignore": ["packages/engine/assets/**", "packages/*/vite.config.ts"],
  "ignoreDependencies": ["@unterberg/vite-beasties-output"],
  "vike": {
    "entry": "packages/*/{pages,renderer}/**/+*.{js,jsx,ts,tsx,vue,react,solid}",
    "project": "packages/*/{pages,renderer}/**/+*.{js,jsx,ts,tsx,vue,react,solid}"
  },
  "vite": false,
  "ignoreIssues": {
    "packages/engine/src/index.ts": ["exports", "types"]
  }
}
